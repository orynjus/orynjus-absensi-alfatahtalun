{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build",
    "watchPatterns": ["**/*.ts", "**/*.tsx", "**/*.json", "package*.json"]
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyType": "ON_FAILURE",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 100,
    "readinessPath": "/api/health",
    "numReplicas": 1
  }
}
