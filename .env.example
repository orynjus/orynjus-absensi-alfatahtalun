# ============================================================
# ENVIRONMENT VARIABLES - Salin file ini menjadi .env
# ============================================================

# === DATABASE ===
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/absensi_alfatah

# === SERVER ===
NODE_ENV=production
PORT=5000

# === SESSION ===
# Ganti dengan string acak yang panjang (min 32 karakter)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=ganti_dengan_string_rahasia_yang_panjang_dan_acak

# === FONNTE (WhatsApp Notification) - Opsional ===
# Dapatkan token di https://fonnte.com
FONNTE_TOKEN=

# === GOOGLE (Google Sheets & Drive) - Opsional ===
# Konfigurasi dilakukan melalui halaman Settings di Admin Dashboard
